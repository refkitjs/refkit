{
  "name": "refkit",
  "version": "0.0.0",
  "private": true,
  "description": "Neutral reference-retrieval toolkit for creative work: license-normalized, dual-modal (visual + text), agent-callable. @refkit/core brain + provider satellites.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "build": "pnpm -r --if-present build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --if-present build && changeset publish"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6",
    "@changesets/cli": "^2.27.0"
  }
}
